# =============================================================================
# ESTOCA INVENTORY CONSOLIDATION - VARIÁVEIS DE AMBIENTE
# =============================================================================
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA commite o arquivo .env em repositórios de código.
# =============================================================================

ESTOCA_BASE_URL=https://api.estoca.com.br

# -----------------------------------------------------------------------------
# LOJA 0102 — Filial MG
# -----------------------------------------------------------------------------
ESTOCA_0102_B2B_API_KEY=your_api_key_here
ESTOCA_0102_B2C_API_KEY=your_api_key_here
# MKT e CROSS compartilham a mesma chave (dedup_group: 0102_MKT_CROSS)
ESTOCA_0102_MKT_API_KEY=your_api_key_here
ESTOCA_0102_CROSS_API_KEY=your_api_key_here

# -----------------------------------------------------------------------------
# LOJA 0103 — Filial Lapa SP
# -----------------------------------------------------------------------------
ESTOCA_0103_B2B_API_KEY=your_api_key_here
ESTOCA_0103_B2C_API_KEY=your_api_key_here
ESTOCA_0103_MKT_API_KEY=your_api_key_here
ESTOCA_0103_CROSS_API_KEY=your_api_key_here

# -----------------------------------------------------------------------------
# AVARIAS — Ollie Avarias Lapa (visível no detalhado, excluída do consolidado)
# -----------------------------------------------------------------------------
ESTOCA_AVARIAS_LAPA_API_KEY=your_api_key_here
